{
  "name": "alloul-mobile",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "export:web": "expo export -p web",
    "typecheck": "tsc --noEmit",
    "eas:update:prod": "EAS_SKIP_AUTO_FINGERPRINT=1 eas update --branch production --environment production --message \"update\"",
    "eas:update:preview": "EAS_SKIP_AUTO_FINGERPRINT=1 eas update --branch preview --environment preview --message \"preview update\"",
    "eas:build:ios": "eas build -p ios --profile production",
    "eas:build:ios:preview": "eas build -p ios --profile preview",
    "eas:build:android": "eas build -p android --profile production",
    "eas:build:android:preview": "eas build -p android --profile preview",
    "eas:submit:ios": "eas submit -p ios --profile production --latest"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.3",
    "@react-native-async-storage/async-storage": "^1.24.0",
    "@react-navigation/bottom-tabs": "^7.15.6",
    "@react-navigation/drawer": "^7.9.5",
    "@react-navigation/native": "^7.1.34",
    "@react-navigation/native-stack": "^7.14.6",
    "expo": "~54.0.0",
    "expo-asset": "~12.0.12",
    "expo-auth-session": "~6.2.0",
    "expo-constants": "~18.0.13",
    "expo-localization": "^55.0.9",
    "expo-notifications": "~0.32.16",
    "expo-secure-store": "~15.0.8",
    "expo-status-bar": "~3.0.9",
    "expo-updates": "~29.0.16",
    "expo-web-browser": "~15.0.10",
    "firebase": "^10.12.4",
    "i18next": "^25.10.5",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-i18next": "^16.6.2",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-web": "^0.21.0",
    "react-native-worklets": "~0.5.2"
  },
  "devDependencies": {
    "@expo/ngrok": "^4.1.3",
    "@types/react": "^19.2.14",
    "babel-preset-expo": "^55.0.12",
    "dotenv": "^16.4.5",
    "typescript": "~5.9.2"
  },
  "private": true
}
