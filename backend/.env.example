# Copy to .env and adjust. Never commit real secrets.

DATABASE_URL=sqlite:///./app.db
SECRET_KEY=change-me-use-openssl-rand-hex-32
ACCESS_TOKEN_EXPIRE_MINUTES=10080
ENVIRONMENT=development
CORS_ORIGINS=http://localhost:8081,http://127.0.0.1:8081

# Production example — أصول الويب التي تستدعي الـ API من المتصفح (Origin). أضف apex + www إن كان الاثنان يُستخدمان.
# CORS_ORIGINS=https://www.alloul.app,https://alloul.app,https://www.aloullone.com,https://aloullone.com
# FRONTEND_URL=https://www.alloul.app

# ── Bootstrap users (dev / QA only — disable in production) ─────────────────
# Primary admin (password min 12 chars). Created on API startup if not already present.
SEED_ADMIN_ENABLED=false
SEED_ADMIN_EMAIL=
SEED_ADMIN_USERNAME=admin
SEED_ADMIN_PASSWORD=

# Second account: same API, another phone (password min 8 chars). Idempotent.
# For TWO admins: put BOTH emails below in ADMIN_ALLOWED_EMAILS and BOTH usernames in ADMIN_USERNAMES.
# For admin + normal user: only the first user’s email in ADMIN_ALLOWED_EMAILS (or rely on username admin only).
SEED_SECOND_USER_ENABLED=false
SEED_SECOND_USER_EMAIL=
SEED_SECOND_USER_USERNAME=tester_b
SEED_SECOND_USER_PASSWORD=
SEED_SECOND_USER_NAME=Tester B

# Example — two devices, both admin (full /admin + is_admin in app):
# SEED_ADMIN_ENABLED=true
# SEED_ADMIN_EMAIL=qa-a@local.test
# SEED_ADMIN_USERNAME=admin
# SEED_ADMIN_PASSWORD=YourSecurePassPhrase12
# SEED_SECOND_USER_ENABLED=true
# SEED_SECOND_USER_EMAIL=qa-b@local.test
# SEED_SECOND_USER_USERNAME=admin_b
# SEED_SECOND_USER_PASSWORD=YourSecurePassPhrase12
# SEED_SECOND_USER_NAME=QA Admin B
# ADMIN_ALLOWED_EMAILS=qa-a@local.test,qa-b@local.test
# ADMIN_USERNAMES=admin,admin_b

# Admin API (/admin/*) and is_admin on GET /auth/me — comma-separated, case-insensitive
# QA: comma-separated emails get is_admin + company workspace without Stripe (restart API after change).
# ADMIN_ALLOWED_EMAILS=m.110m@gmail.com
ADMIN_ALLOWED_EMAILS=
ADMIN_USERNAMES=admin,mbtalm1

# Google / Firebase — server verifies id_token from the app (POST /auth/firebase)
GOOGLE_APPLICATION_CREDENTIALS=
FIREBASE_PROJECT_ID=

# Azure AD (POST /auth/azure-ad)
MICROSOFT_CLIENT_ID=
MICROSOFT_TENANT_ID=

# Daily.co — مكالمات فيديو + شات داخل الغرفة لأعضاء الشركة (GET /daily/company-join)
# DAILY_API_KEY=
# DAILY_SUBDOMAIN=your-subdomain

# Stripe, Azure Blob, Anthropic — see config.py for full list
